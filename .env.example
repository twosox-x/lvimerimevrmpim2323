# Database
DATABASE_URL=postgres://user:password@localhost:5432/loot_tv

# App / API
PORT=3001
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
AUTH_SECRET=replace-with-32-plus-random-bytes
ENCRYPTION_KEY=replace-with-32-plus-random-bytes-or-64-hex-chars

# Frontend
VITE_API_BASE_URL=http://localhost:3001
# Local preview can use demo mode. Production should set this to false unless intentionally running a demo.
VITE_DEMO_MODE=true

# Base payments
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
L00T_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Streaming provider
# Use "stub" for local development. Production adapters can be wired behind the provider interface.
STREAM_PROVIDER=stub
RTMP_INGEST_URL=rtmp://ingest.l00t.tv/live
PLAYBACK_BASE_URL=https://playback.l00t.tv

# LiveKit, if selected later
LIVEKIT_API_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
